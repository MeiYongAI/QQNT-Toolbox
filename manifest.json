{
  "manifest_version": 4,
  "type": "extension",
  "name": "QQNT Toolbox",
  "slug": "qqnt_toolbox",
  "description": "LiteLoaderQQNT 工具箱，包含文件发送修复、消息复读、语音库、阻止撤回、拍一拍和界面调整。",
  "version": "0.6.3",
  "authors": [
    {
      "name": "MeiYongAI",
      "link": "https://github.com/MeiYongAI"
    }
  ],
  "repository": {
    "repo": "MeiYongAI/QQNT-Toolbox",
    "branch": "main"
  },
  "platform": [
    "win32",
    "linux",
    "darwin"
  ],
  "injects": {
    "main": "./src/main.js",
    "preload": "./src/preload.js",
    "renderer": "./src/renderer.js"
  }
}
